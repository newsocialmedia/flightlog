# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── RapidAPI / AeroDataBox ────────────────────────────────────────────────────
# Get from: rapidapi.com → AeroDataBox → Subscribe → Copy API Key
# Used for automatic tail number and block time lookup
VITE_RAPIDAPI_KEY=your-rapidapi-key-here

# ── Stripe (optional — for subscription billing) ──────────────────────────────
# Get from: dashboard.stripe.com → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Note: STRIPE_SECRET_KEY goes in Supabase secrets, NOT here
